# Build and run the Radiant Seeder from GitHub repository
# Usage:
#   docker build -f docker/Dockerfile.seeder -t radiant-seeder --build-arg GIT_TAG=main .
#   docker run --rm -it -p 5353:53/udp radiant-seeder -host=dnsseed.example.com -ns=vps.example.com

FROM ubuntu:24.04

LABEL maintainer="info@radiantfoundation.org"
LABEL description="Radiant Seeder built from GitHub repository"

ENV DEBIAN_FRONTEND=noninteractive

# Build arguments
ARG GIT_TAG=main
ARG BUILD_TYPE=Release

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    pkg-config \
    libtool \
    autoconf \
    automake \
    libevent-dev \
    libboost-chrono-dev \
    libboost-filesystem-dev \
    libboost-test-dev \
    libboost-thread-dev \
    libminiupnpc-dev \
    libssl-dev \
    libzmq3-dev \
    libdb++-dev \
    python3 \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt

# Clone from GitHub repository
RUN git clone --depth 1 --branch ${GIT_TAG} https://github.com/Radiant-Core/Radiant-Core.git radiant-seeder

WORKDIR /opt/radiant-seeder

# Configure and build: Enable Seeder, Disable everything else
RUN mkdir -p build \
 && cd build \
 && cmake -GNinja .. \
    -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
    -DBUILD_RADIANT_SEEDER=ON \
    -DBUILD_RADIANT_DAEMON=OFF \
    -DBUILD_RADIANT_WALLET=OFF \
    -DBUILD_RADIANT_QT=OFF \
    -DBUILD_RADIANT_CLI=OFF \
    -DBUILD_RADIANT_TX=OFF \
    -DBUILD_RADIANT_ZMQ=OFF \
 && ninja radiant-seeder

WORKDIR /opt/radiant-seeder/build/src/seeder

EXPOSE 53/udp

ENTRYPOINT ["./radiant-seeder"]
