# Radiant Testnet Docker Configuration
# ============================================================================
# DEVELOPMENT/TESTING ONLY - Requires pre-built LOCAL binaries
# ============================================================================
# This Dockerfile expects binaries to be already built locally in build/src/
# It does NOT build from source or clone from GitHub.
#
# Usage:
#   1. Build the project first: cmake -B build && cmake --build build
#   2. Then build this image: docker build -f docker/Dockerfile.testnet -t radiant-testnet .
#
# For production builds, use: docker/Dockerfile.release
# ============================================================================
# Uses -testnet flag for the public Radiant testnet network
# P2P Port: 27333, RPC Port: 27332
# ============================================================================

FROM ubuntu:24.04

LABEL maintainer="info@radiantfoundation.org"
LABEL description="Radiant Core Node - Testnet Configuration (LOCAL BUILD)"

# Install runtime dependencies
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    libboost-chrono1.83.0 \
    libboost-filesystem1.83.0 \
    libboost-thread1.83.0 \
    libboost-atomic1.83.0 \
    libevent-2.1-7 \
    libssl3 \
    libdb5.3++ \
    libminiupnpc17 \
    libzmq5 \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create radiant user for security
RUN useradd -m -s /bin/bash radiant

# Set working directory
WORKDIR /home/radiant

# Copy pre-built local binaries and configuration (DEVELOPMENT ONLY)
COPY build/src/radiantd /usr/local/bin/
COPY build/src/radiant-cli /usr/local/bin/
COPY build/src/radiant-wallet /usr/local/bin/
COPY radiant-testnet.conf /home/radiant/

# Create data and wallet directories
RUN mkdir -p /home/radiant/data-testnet /home/radiant/wallets-testnet

# Change ownership to radiant user
RUN chown -R radiant:radiant /home/radiant

# Switch to radiant user
USER radiant

# Expose Radiant Testnet ports
# P2P Port: 27333, RPC Port: 27332, ZMQ Port: 29000
EXPOSE 27333 27332 29000

# Start Radiant Testnet node with wallet support
CMD ["radiantd", "-conf=/home/radiant/radiant-testnet.conf"]
